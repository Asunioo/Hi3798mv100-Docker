name: Build Mainline Kernel for Hi3798MV100 (Debian 12 Ready)

on:
  workflow_dispatch: # 允许手动触发
    inputs:
      kernel_version:
        description: 'Kernel Version Tag (e.g., v6.1.64, v6.6.15)'
        required: true
        default: 'v6.6.15'
      base_defconfig:
        description: 'Base Defconfig Name'
        required: false
        default: 'multi_v7_defconfig'

jobs:
  build-kernel:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Install Dependencies & Toolchain
        run: |
          sudo apt-get update
          sudo apt-get install -y bc bison flex libssl-dev make libc6-dev libncurses5-dev crossbuild-essential-armhf
          echo "ARCH=arm" >> $GITHUB_ENV
          echo "CROSS_COMPILE=arm-linux-gnueabihf-" >> $GITHUB_ENV

      - name: Clone Kernel Source
        run: |
          git clone --depth 1 --branch ${{ github.event.inputs.kernel_version }} https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git linux
          cd linux

      - name: Configure Kernel & Enable Docker Features
        run: |
          cd linux
          # 1. 生成基础配置
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- ${{ github.event.inputs.base_defconfig }}

          # 2. 强制开启 Docker 和 Debian 12 所需的关键特性
          # 注意顺序：必须先开启 USER_NS，否则 CGROUP_NS 无法开启
          ./scripts/config --enable NAMESPACES
          ./scripts/config --enable USER_NS
          ./scripts/config --enable CGROUPS
          ./scripts/config --enable CGROUP_NS
          ./scripts/config --enable NETFILTER_XT_MATCH_ADDRTYPE
          ./scripts/config --enable NETFILTER_XT_MATCH_IPVS
          ./scripts/config --enable IP_VS
          ./scripts/config --enable IP_VS_NFCT
          ./scripts/config --enable IP_VS_PROTO_TCP
          ./scripts/config --enable IP_VS_PROTO_UDP
          ./scripts/config --enable IP_VS_RR
          ./scripts/config --enable OVERLAY_FS
          ./scripts/config --enable BRIDGE
          ./scripts/config --enable BRIDGE_VLAN_FILTERING

          # 3. 处理依赖关系并应用更改
          # 这一步至关重要，它会解决因为缺少依赖而被禁用的问题
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- olddefconfig

          # 4. 验证关键配置是否真的生效了 (防止静默失败)
          if ! grep -q "CONFIG_CGROUP_NS=y" .config; then
            echo "Error: CONFIG_CGROUP_NS is still not enabled!"
            grep "CGROUP_NS" .config || true
            exit 1
          fi

      - name: Verify Configuration (Debug)
        run: |
          cd linux
          echo "=== Checking Critical Configs ==="
          grep "CONFIG_CGROUP_NS" .config
          grep "CONFIG_USER_NS" .config
          grep "CONFIG_OVERLAY_FS" .config

      - name: Build Kernel
        run: |
          cd linux
          # 编译 zImage 和 dtbs
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- -j$(nproc) zImage dtbs modules

      - name: Package Artifacts
        run: |
          mkdir -p artifacts
          cp linux/arch/arm/boot/zImage artifacts/
          cp linux/arch/arm/boot/dts/*.dtb artifacts/ || true # 忽略如果没有dtb的情况
          # 打包模块 (可选，视您的需求而定)
          # make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- INSTALL_MOD_PATH=../artifacts/modules modules_install

      - name: Upload Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: hi3798mv100-kernel-${{ github.event.inputs.kernel_version }}
          path: artifacts/
