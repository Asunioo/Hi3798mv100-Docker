name: Build Mainline Kernel for Hi3798MV100 (Debian 12 Ready)

on:
  workflow_dispatch: # 允许手动触发
    inputs:
      kernel_version:
        description: 'Kernel Version Tag (e.g., v6.1.64, v6.6.15)'
        required: true
        default: 'v6.6.15'
      base_defconfig:
        description: 'Base Defconfig Name'
        required: false
        default: 'multi_v7_defconfig'

jobs:
  build-kernel:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Install Dependencies & Toolchain
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            bc bison flex libssl-dev make libc6-dev libncurses5-dev \
            crossbuild-essential-armhf dwarves cpio kmod lzop u-boot-tools

      - name: Download Kernel Source
        run: |
          git clone --depth 1 --branch ${{ github.event.inputs.kernel_version }} https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git linux-src

      - name: Configure Kernel Base
        run: |
          cd linux-src
          export ARCH=arm
          export CROSS_COMPILE=arm-linux-gnueabihf-
          make ${{ github.event.inputs.base_defconfig }}

      - name: Force Enable Docker & Debian 12 Features
        run: |
          cd linux-src
          export ARCH=arm
          export CROSS_COMPILE=arm-linux-gnueabihf-

          echo "=== Patching .config for Cgroup NS and Docker ==="

          # 1. 开启基础命名空间支持 (CGROUP_NS 的强依赖)
          scripts/config --enable NAMESPACES
          scripts/config --enable USER_NS

          # 2. 开启 Cgroup Namespace
          scripts/config --enable CGROUP_NS

          # 3. 开启 Docker 网络桥接支持
          scripts/config --enable BRIDGE
          scripts/config --enable BRIDGE_NETFILTER
          scripts/config --enable BRIDGE_VLAN_FILTERING
          scripts/config --enable IP_NF_TARGET_MASQUERADE
          scripts/config --enable NETFILTER_XT_MATCH_ADDRTYPE

          # 4. 开启 OverlayFS (Docker 存储驱动必须)
          scripts/config --enable OVERLAY_FS

          # 5. 开启其他容器常用功能
          scripts/config --enable VETH
          scripts/config --enable IP_VS
          scripts/config --enable NF_CONNTRACK
          scripts/config --enable NET_NS

          # 关键步骤：重新应用默认值以解析依赖关系
          # 这会将刚才开启的选项“固化”，并处理未满足的子依赖
          yes "" | make oldconfig

          # 验证关键选项是否真的被开启了
          echo "=== Verifying Configuration ==="
          grep -E "CONFIG_CGROUP_NS|CONFIG_USER_NS|CONFIG_OVERLAY_FS" .config || true

          if ! grep -q "CONFIG_CGROUP_NS=y" .config; then
             echo "::error::Failed to enable CONFIG_CGROUP_NS. Check dependencies."
             exit 1
          fi

      - name: Compile Kernel
        run: |
          cd linux-src
          export ARCH=arm
          export CROSS_COMPILE=arm-linux-gnueabihf-
          export CONCURRENCY_LEVEL=$(nproc)

          # 编译 zImage 和 dtbs (设备树)
          make -j$(nproc) zImage dtbs modules

      - name: Install Modules
        run: |
          cd linux-src
          export ARCH=arm
          export CROSS_COMPILE=arm-linux-gnueabihf-
          export INSTALL_MOD_PATH=../modules_install
          make modules_install

      - name: Package Artifacts
        run: |
          mkdir -p artifacts
          cp linux-src/arch/arm/boot/zImage artifacts/
          cp linux-src/arch/arm/boot/dts/*.dtb artifacts/ || true
          cp linux-src/.config artifacts/config_${{ github.event.inputs.kernel_version }}

          # 打包模块
          tar czf artifacts/modules.tar.gz -C modules_install lib/modules

      - name: Upload Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: hi3798mv100-kernel-${{ github.event.inputs.kernel_version }}
          path: artifacts/
