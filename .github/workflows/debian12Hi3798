name: Build Mainline Kernel for Hi3798MV100 (Docker Ready)

on:
  workflow_dispatch: # 允许手动触发
    inputs:
      kernel_version:
        description: 'Kernel Version (e.g., v6.6.15)'
        required: true
        default: 'v6.6.15'
      custom_defconfig:
        description: 'Base Defconfig Name'
        required: false
        default: 'multi_v7_defconfig'

jobs:
  build-kernel:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Install Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y bc bison flex libssl-dev make libc6-dev libncurses5-dev crossbuild-essential-armhf kmod cpio xz-utils

      - name: Setup Cross Compilation Toolchain
        run: |
          echo "ARCH=arm" >> $GITHUB_ENV
          echo "CROSS_COMPILE=arm-linux-gnueabihf-" >> $GITHUB_ENV

      - name: Clone Linux Source
        run: |
          git clone --depth 1 --branch ${{ github.event.inputs.kernel_version }} https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git linux-source

      - name: Configure Kernel (Base + Docker Fixes)
        run: |
          cd linux-source
          # 1. 生成基础配置
          make ${{ github.event.inputs.custom_defconfig }}

          # 2. 强制启用 Docker 和 Debian 12 所需的关键选项
          # 使用 sed 直接修改 .config 文件，比 scripts/config 更稳健
          cat <<EOF >> .config
          CONFIG_CGROUP_NS=y
          CONFIG_PID_NS=y
          CONFIG_NET_NS=y
          CONFIG_IPC_NS=y
          CONFIG_UTS_NS=y
          CONFIG_USER_NS=y
          CONFIG_CGROUPS=y
          CONFIG_CGROUP_CPUACCT=y
          CONFIG_CGROUP_DEVICE=y
          CONFIG_CGROUP_FREEZER=y
          CONFIG_CGROUP_SCHED=y
          CONFIG_MEMCG=y
          CONFIG_NAMESPACES=y
          CONFIG_OVERLAY_FS=y
          CONFIG_VETH=y
          CONFIG_BRIDGE=y
          CONFIG_BRIDGE_NETFILTER=y
          CONFIG_IP_NF_FILTER=y
          CONFIG_IP_NF_TARGET_MASQUERADE=y
          CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
          CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
          CONFIG_NETFILTER_XT_MATCH_IPVS=y
          CONFIG_IP_VS=y
          CONFIG_IP_VS_NFCT=y
          CONFIG_IP_VS_PROTO_TCP=y
          CONFIG_IP_VS_PROTO_UDP=y
          CONFIG_IP_VS_RR=y
          CONFIG_EXT4_FS=y
          CONFIG_EXT4_FS_POSIX_ACL=y
          CONFIG_EXT4_FS_SECURITY=y
          EOF

          # 3. 解决依赖关系并清理无效选项
          # olddefconfig 会自动处理新加入选项的依赖，并将冲突项设为默认值
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- olddefconfig

          # 4. 验证关键选项是否真的生效
          echo "--- Verifying Configuration ---"
          grep CONFIG_CGROUP_NS .config || exit 1
          grep CONFIG_OVERLAY_FS .config || exit 1
          grep CONFIG_USER_NS .config || exit 1
          echo "--- Verification Passed ---"

      - name: Compile Kernel
        run: |
          cd linux-source
          # 使用所有可用核心编译，生成 zImage 和 dtbs
          make -j$(nproc) ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- zImage modules dtbs

      - name: Install Modules to Staging Directory
        run: |
          mkdir -p output/modules
          cd linux-source
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- INSTALL_MOD_PATH=../output/modules modules_install

      - name: Package Artifacts
        run: |
          mkdir -p output/artifacts
          cp linux-source/arch/arm/boot/zImage output/artifacts/
          cp linux-source/arch/arm/boot/dts/hisilicon/*.dtb output/artifacts/ || true # 尝试复制海思dtb，路径可能因版本而异
          cp linux-source/arch/arm/boot/dts/arm/*.dtb output/artifacts/ || true
          tar -czf output/artifacts/modules.tar.gz -C output/modules lib

      - name: Upload Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: hi3798mv100-kernel-${{ github.event.inputs.kernel_version }}
          path: output/artifacts/
