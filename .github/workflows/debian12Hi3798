name: Build Mainline Kernel for Hi3798MV100 (Debian 12 Ready)

on:
  workflow_dispatch: # 允许手动触发
    inputs:
      kernel_version:
        description: 'Kernel Version Tag (e.g., v6.1.64, v6.6.15)'
        required: true
        default: 'v6.6.15'
      base_defconfig:
        description: 'Base Defconfig Name'
        required: false
        default: 'multi_v7_defconfig'

jobs:
  build-kernel:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Install Dependencies & Toolchain
        run: |
          sudo apt-get update
          sudo apt-get install -y bc bison flex libssl-dev make libc6-dev libncurses5-dev crossbuild-essential-armhf
          # 安装 U-Boot 工具用于生成 mkimage (如果需要)
          sudo apt-get install -y u-boot-tools

      - name: Clone Kernel Source
        run: |
          git clone --depth 1 --branch ${{ github.event.inputs.kernel_version }} https://github.com/torvalds/linux.git linux
          cd linux

      - name: Configure Kernel & Enable Docker Features
        run: |
          cd linux
          # 1. 生成基础配置
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- ${{ github.event.inputs.base_defconfig }}

          # 2. 强制开启 Docker/Debian 必须的选项及其依赖
          # 注意：必须按顺序或成组开启，因为存在依赖关系
          scripts/config --enable CONFIG_NAMESPACES
          scripts/config --enable CONFIG_USER_NS
          scripts/config --enable CONFIG_CGROUPS
          scripts/config --enable CONFIG_CGROUP_NS
          scripts/config --enable CONFIG_PID_NS
          scripts/config --enable CONFIG_NET_NS
          scripts/config --enable CONFIG_IPC_NS
          scripts/config --enable CONFIG_UTS_NS
          scripts/config --enable CONFIG_OVERLAY_FS
          scripts/config --enable CONFIG_BRIDGE
          scripts/config --enable CONFIG_BRIDGE_VLAN_FILTERING
          scripts/config --enable CONFIG_VETH
          scripts/config --enable CONFIG_MACVLAN

          # 3. 再次运行 olddefconfig 解决依赖冲突并应用更改
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- olddefconfig

          # 4. 验证关键配置是否真的生效了
          echo "=== Checking Critical Configs ==="
          grep -E "CONFIG_CGROUP_NS|CONFIG_USER_NS|CONFIG_OVERLAY_FS" .config || true

          if ! grep -q "CONFIG_CGROUP_NS=y" .config; then
            echo "::error::CRITICAL ERROR: CONFIG_CGROUP_NS is still not enabled!"
            exit 1
          fi

      - name: Verify Configuration (Debug Step)
        run: |
          cd linux
          echo "--- Verifying Docker Requirements ---"
          ./scripts/config --state CONFIG_CGROUP_NS
          ./scripts/config --state CONFIG_USER_NS
          ./scripts/config --state CONFIG_OVERLAY_FS
          # 如果上面的检查失败，这里会直接报错停止

      - name: Build Kernel
        run: |
          cd linux
          # 编译 zImage 和 dtbs
          make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- -j$(nproc) zImage dtbs modules

      - name: Package Artifacts
        run: |
          mkdir -p output
          cp linux/arch/arm/boot/zImage output/
          cp linux/arch/arm/boot/dts/*.dtb output/ || true # 复制所有 dtb，防止路径问题
          # 打包 modules (可选，视您的根文件系统需求而定)
          # make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- INSTALL_MOD_PATH=output/modules modules_install

      - name: Upload Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: hi3798mv100-kernel-${{ github.event.inputs.kernel_version }}
          path: output/
